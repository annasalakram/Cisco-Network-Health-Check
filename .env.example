# Cisco DevNet Sandbox Credentials Template
# INSTRUCTIONS: Copy this file to a new file named '.env' and fill in the values.

# Hostname or IP Address of the Cisco Sandbox (e.g., sbx-iosxr-mgmt.cisco.com)
DEV_HOST=your_sandbox_hostname_here

# Username for SSH access (e.g., admin or developer)
DEV_USER=your_username_here

# Password for SSH access (e.g., C1sco12345)
DEV_PASS=your_password_here

# SSH Port (22 for standard SSH, or 57722 for IOS-XR XML-Agent)
DEV_PORT=22